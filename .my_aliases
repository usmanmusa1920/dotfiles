# -------------------------------------------------------------


# git short aliases
alias lg='git lg'
alias ssg='git status'
alias ga='git add -A' # OR git add .
alias cgm='git commit -m'
alias gpush='git push origin master'

alias jn='jupyter notebook' # launch jupyter notebook --OR-- jupyter notebook
alias jl='jupyter lab' # launch jupyter lab --OR-- jupyter-lab
alias python='python3'
alias clr='clear && source ~/.bashrc' # for clearing terminal and sourcing bashrc file
alias c='clear' # for clearing terminal
alias ddc='deactivate' # for deactivating virtual environment

