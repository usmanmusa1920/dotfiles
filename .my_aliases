# These are my custom aliases
# -------------------------------------------------------------
# for activating virtual environment
alias sv='source venv/bin/activate'

# running django server
alias pm='python3 manage.py runserver'
# migrating database changes
alias pmigrate='python3 manage.py migrate'
# making database migrations
alias pmake='python3 manage.py makemigrations'
# launching my project in python shell
alias pshell='python3 manage.py shell'


# Entering into my project folder
#     alias <aproject_working_on>='cd ~/Desktop/acode/<project_working_on>'

# Entering into my project folder using the above aliase,
# activating it vartual environment, and
# launching up it server (for django)
#     alias <bproject_name>='<aproject_working_on>  && sv && pm'
# 
#     The prototype of the two above alias look like:
#         alias dfacebook='cd ~/Desktop/acode/facebook'
#         alias facebook='dfacebook && sv && pm'
# 
#           PUT YOUR OWN  HERE...
